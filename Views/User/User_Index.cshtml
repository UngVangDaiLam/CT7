@model IEnumerable<bt1.Product.Product>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "HNTS - Người dùng";
}

<section id="user-page" class="page-section ">

    <nav class="navbar" id="user-navbar" role="navigation" aria-label="Điều hướng chính">
        <div class="container navbar-inner">
            <a href="#" class="nav-logo" aria-label="HNTS Trang chủ" onclick="return false;">
                🛍️ HomNayToi<span class="dot">Suy</span>
            </a>
            <ul class="nav-links" id="nav-links" role="list">
                <li><a href="#" onclick="scrollUserTop()">Trang chủ</a></li>
                <li><a href="#" id="nav-products">Sản phẩm</a></li>
                <li>
                    <a href="#" class="nav-cart-btn" aria-label="Giỏ hàng">
                        🛒 Giỏ hàng
                        <span class="cart-count" id="cart-count" style="display:none">0</span>
                    </a>
                </li>
                <li id="nav-login-wrap">
                    <button class="nav-login-btn" id="nav-login-btn" type="button">🔑 Đăng nhập</button>
                </li>
                <li id="nav-logout-wrap" style="display:none;">
                    <span id="nav-username" class="nav-username-text"></span>
                    <button class="nav-logout" id="user-logout-btn" type="button">Đăng xuất</button>
                </li>
            </ul>
            <button class="hamburger" id="hamburger" aria-label="Mở menu" aria-expanded="false" type="button">
                <span></span><span></span><span></span>
            </button>
        </div>
    </nav>

    <div class="user-scroll-wrap" id="user-scroll-wrap">
        <section class="hero" role="banner">
            <div class="hero-bg-art"></div>
            <div class="container">
                <div class="hero-content">
                    <div class="hero-badge">✨ Ưu đãi hàng ngày</div>
                    <h1>
                        Mua sắm dễ dàng,
                        <span class="highlight">giá tốt mỗi ngày</span>
                    </h1>
                    <p>
                        Khám phá hàng ngàn sản phẩm chất lượng cao với giá cả phải chăng.
                        Giao hàng nhanh, đổi trả miễn phí trong 30 ngày.
                    </p>
                    <div class="hero-btns">
                        <button class="btn-primary" id="hero-cta" type="button">Xem sản phẩm 👇</button>
                        <button class="btn-secondary" type="button">Ưu đãi hôm nay 🔥</button>
                    </div>
                    <div class="hero-stats">
                        <div class="stat-item">
                            <div class="stat-num">10K<span>+</span></div>
                            <div class="stat-label">Sản phẩm</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-num">50K<span>+</span></div>
                            <div class="stat-label">Khách hàng</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-num">99<span>%</span></div>
                            <div class="stat-label">Hài lòng</div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <main>
            <section id="products-section" class="section">
                <div class="container">
                    <header class="section-header">
                        <div class="section-tag">🛒 Sản phẩm</div>
                        <h2>Khám phá bộ sưu tập</h2>
                        <p>Những sản phẩm được yêu thích nhất, chọn lọc kỹ lưỡng cho bạn</p>
                    </header>

                    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-4" id="product-grid" role="list" aria-label="Danh sách sản phẩm">

                        @if (Model != null && Model.Any())
                        {
                            foreach (var p in Model)
                            {
                                <div class="col">
                                    <div class="card h-100 shadow-sm" style="border-radius: 12px; overflow: hidden; border: 1px solid #eee;">
                                        <img src="@(p.Images != null && p.Images.Any() ? p.Images.First().Url : "/images/default-product.jpg")" class="card-img-top" alt="@p.Name" style="height: 220px; object-fit: cover;">

                                        <div class="card-body d-flex flex-column">
                                            <h5 class="card-title text-truncate" style="font-size: 1.1rem; font-weight: 600;" title="@p.Name">@p.Name</h5>

                                            <p class="card-text text-danger fw-bold mb-3" style="font-size: 1.2rem;">
                                                @string.Format("{0:N0} đ", p.Price)
                                            </p>

                                            <button class="btn btn-primary w-100 mt-auto" onclick="addToCart(@p.Id)" style="border-radius: 8px; font-weight: 500;">
                                                Thêm vào giỏ
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="col-12 text-center py-5">
                                <p style="font-size: 1.2rem; color: #6b6b8a;">Hiện chưa có sản phẩm nào trong hệ thống.</p>
                            </div>
                        }

                    </div>
                </div>
            </section>
        </main>

        <footer class="footer" role="contentinfo">
            <div class="container">
                <div class="footer-grid">
                    <div class="footer-brand">
                        <div class="logo-text">🛍️ HNTS</div>
                        <p>Nền tảng mua sắm trực tuyến hàng đầu Việt Nam. Mang đến trải nghiệm mua sắm dễ dàng, tiện lợi và tiết kiệm cho mọi gia đình.</p>
                        <div class="footer-socials">
                            <a href="#" class="social-btn" aria-label="Facebook">📘</a>
                            <a href="#" class="social-btn" aria-label="Instagram">📸</a>
                            <a href="#" class="social-btn" aria-label="TikTok">🎵</a>
                            <a href="#" class="social-btn" aria-label="YouTube">▶️</a>
                        </div>
                    </div>
                    <div class="footer-col">
                        <h4>Liên kết nhanh</h4>
                        <ul>
                            <li><a href="#">Trang chủ</a></li>
                            <li><a href="#">Sản phẩm mới</a></li>
                            <li><a href="#">Về chúng tôi</a></li>
                            <li><a href="#">Blog thời trang</a></li>
                            <li><a href="#">Chính sách đổi trả</a></li>
                        </ul>
                    </div>
                    <div class="footer-col footer-contact">
                        <h4>Liên hệ</h4>
                        <p><span class="icon">📍</span>123 Đường Lê Lợi, Q.1, TP.HCM</p>
                        <p><span class="icon">📞</span>1800 1234 (Miễn phí)</p>
                        <p><span class="icon">✉️</span>support@hnts.vn</p>
                        <p><span class="icon">🕐</span>Thứ 2 – Chủ nhật: 8:00 – 22:00</p>
                    </div>
                </div>
                <div class="footer-bottom">
                    <p>© 2026 HNTS. Tất cả quyền được bảo lưu.</p>
                    <p>Được tạo với <span class="heart">❤️</span> tại Việt Nam</p>
                </div>
            </div>
        </footer>
    </div>
</section>
