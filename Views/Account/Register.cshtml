@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "HNTS - Đăng ký";
}

<div class="register-page" style="min-height: 100vh; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 20px;">
    <div class="register-box" style="background: white; border-radius: 15px; padding: 40px; width: 100%; max-width: 400px; box-shadow: 0 10px 40px rgba(0,0,0,0.2);">

        <div class="register-header" style="text-align: center; margin-bottom: 30px;">
            <div style="font-size: 3rem; margin-bottom: 10px;">🛍️</div>
            <h2 style="margin: 0; color: #333; font-size: 24px;">HNTS Store</h2>
            <p style="color: #999; margin-top: 5px;">Đăng ký tài khoản mới</p>
        </div>

        @if (TempData["Error"] != null)
        {
            <div style="background: #fee; color: #c33; padding: 12px; border-radius: 8px; margin-bottom: 20px; border-left: 4px solid #c33;">
                @TempData["Error"]
            </div>
        }

        <form action="/Account/Register" method="post" style="display: flex; flex-direction: column; gap: 15px;">
            @Html.AntiForgeryToken()

            <div>
                <label for="username" style="display: block; margin-bottom: 5px; color: #555; font-weight: 500;">Tên đăng nhập</label>
                <input type="text" id="username" name="username" placeholder="Nhập tên đăng nhập (3+ ký tự)" required
                       style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-size: 14px; box-sizing: border-box;">
            </div>

            <div>
                <label for="email" style="display: block; margin-bottom: 5px; color: #555; font-weight: 500;">Email</label>
                <input type="email" id="email" name="email" placeholder="Nhập email" required
                       style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-size: 14px; box-sizing: border-box;">
            </div>

            <div>
                <label for="fullName" style="display: block; margin-bottom: 5px; color: #555; font-weight: 500;">Họ và tên</label>
                <input type="text" id="fullName" name="fullName" placeholder="Nhập họ và tên" required
                       style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-size: 14px; box-sizing: border-box;">
            </div>

            <div>
                <label for="password" style="display: block; margin-bottom: 5px; color: #555; font-weight: 500;">Mật khẩu</label>
                <input type="password" id="password" name="password" placeholder="Nhập mật khẩu (6+ ký tự)" required
                       style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-size: 14px; box-sizing: border-box;">
            </div>

            <div>
                <label for="confirmPassword" style="display: block; margin-bottom: 5px; color: #555; font-weight: 500;">Xác nhận mật khẩu</label>
                <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Nhập lại mật khẩu" required
                       style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-size: 14px; box-sizing: border-box;">
            </div>

            <button type="submit" style="width: 100%; padding: 12px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; border-radius: 8px; font-size: 16px; font-weight: 600; cursor: pointer; margin-top: 10px;">
                Đăng ký ngay
            </button>
        </form>

        <div style="text-align: center; margin-top: 20px; color: #999;">
            Đã có tài khoản? <a href="/" style="color: #667eea; text-decoration: none; font-weight: 600;">Đăng nhập</a>
        </div>
    </div>
</div>