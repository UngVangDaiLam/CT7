@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Admin - Quản lý sản phẩm";

    var products = ViewBag.Products as List<bt1.Product.Product> ?? new List<bt1.Product.Product>();
    var categories = ViewBag.Categories as List<bt1.Category.Category> ?? new List<bt1.Category.Category>();
    var editProduct = ViewBag.EditProduct as bt1.Product.Product;
    var isEditing = editProduct != null;

    var editPrice = isEditing
        ? editProduct!.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)
        : "";

    var totalProducts = products.Count;
    var maxPrice = products.Any() ? products.Max(p => p.Price) : 0;
    var totalValue = products.Sum(p => p.Price);
    var outOfStock = products.Count(p => p.Status == "OutOfStock");
    var productFormAction = Url.Action(isEditing ? "EditProduct" : "AddProduct", "Admin");

    // ----- Danh mục (gộp vào trang Admin) -----
    var categoriesPaged = ViewBag.CategoriesPaged as List<bt1.Category.Category> ?? new List<bt1.Category.Category>();
    var editCategory = ViewBag.EditCategory as bt1.Category.Category;
    var isEditingCat = editCategory != null;
    int catCurPage = ViewBag.CatCurrentPage != null ? (int)ViewBag.CatCurrentPage : 1;
    int catTotPages = ViewBag.CatTotalPages != null ? (int)ViewBag.CatTotalPages : 1;
    string catSv = ViewBag.CatSearch as string ?? "";
}

<section id="admin-page" class="page-section">

    <!-- ADMIN NAVBAR -->
    <nav class="admin-navbar" role="navigation" aria-label="Admin navigation">
        <div class="admin-navbar-inner">
            <div class="admin-logo">
                🛍️ HNTS
                <span class="admin-logo-badge">Admin</span>
            </div>

            <ul class="admin-nav-links" role="list">
                <li>
                    <a href="#" class="active" onclick="return false;">📦 Quản lý sản phẩm</a>
                </li>
                <li>
                    <button id="admin-logout-btn" type="button">🚪 Đăng xuất</button>
                </li>
            </ul>
        </div>
    </nav>

    <!-- ADMIN LAYOUT -->
    <div class="admin-layout">

        <!-- SIDEBAR -->
        <aside class="admin-sidebar" role="complementary" aria-label="Sidebar">
            <div class="sidebar-section">
                <div class="sidebar-title">Tổng quan</div>

                <button class="sidebar-link active" type="button">
                    <span class="icon">📊</span> Dashboard
                </button>

                <button class="sidebar-link" type="button"
                        onclick="document.getElementById('product-form-section').scrollIntoView({behavior:'smooth'})">
                    <span class="icon">📦</span> Quản lý sản phẩm
                </button>

                <button class="sidebar-link" type="button"
                        onclick="document.getElementById('admin-category-section').scrollIntoView({behavior:'smooth'})">
                    <span class="icon">🗂️</span> Quản lý danh mục
                </button>

                <button class="sidebar-link" type="button" onclick="window.location.href='/Admin/ManageUsers'">
                    <span class="icon">👥</span> Quản lý người dùng
                </button>

            </div>

            <div class="sidebar-section">
                <div class="sidebar-title">Hệ thống</div>

                <button class="sidebar-link" type="button" id="sidebar-logout">
                    <span class="icon">🚪</span> Đăng xuất
                </button>
            </div>
        </aside>

        <!-- MAIN CONTENT -->
        <main class="admin-main" role="main">

            <!-- PAGE TITLE -->
            <div class="mb-4">
                <h1 style="font-family:var(--font-display);font-size:1.7rem;font-weight:700;color:var(--admin-primary);letter-spacing:-0.5px;">
                    📦 Quản lý sản phẩm
                </h1>

                <p style="color:#94a3b8;font-size:0.9rem;margin-top:4px;">
                    Thêm, xóa và quản lý toàn bộ sản phẩm trên cửa hàng bằng SQL Server.
                </p>
            </div>

            <!-- TEMP DATA MESSAGE -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success mb-3">
                    ✅ @TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger mb-3">
                    ❌ @TempData["Error"]
                </div>
            }

            <!-- STATS GRID -->
            <div class="stats-grid">
                <div class="stat-card shadow-sm">
                    <div class="stat-icon blue">📦</div>
                    <div class="stat-info">
                        <div class="stat-val">@totalProducts</div>
                        <div class="stat-lbl">Tổng sản phẩm</div>
                    </div>
                </div>

                <div class="stat-card shadow-sm">
                    <div class="stat-icon red">🏆</div>
                    <div class="stat-info">
                        <div class="stat-val" style="font-size:1.15rem;">@maxPrice.ToString("#,##0") đ</div>
                        <div class="stat-lbl">Giá cao nhất</div>
                    </div>
                </div>

                <div class="stat-card shadow-sm">
                    <div class="stat-icon green">💰</div>
                    <div class="stat-info">
                        <div class="stat-val" style="font-size:1.15rem;">@totalValue.ToString("#,##0") đ</div>
                        <div class="stat-lbl">Tổng giá trị</div>
                    </div>
                </div>

                <div class="stat-card shadow-sm">
                    <div class="stat-icon orange">🚫</div>
                    <div class="stat-info">
                        <div class="stat-val">@outOfStock</div>
                        <div class="stat-lbl">Hết hàng</div>
                    </div>
                </div>
            </div>

            <!-- PRODUCT FORM -->
            <div class="admin-card" id="product-form-section">
                <div class="admin-card-header">
                    <h3>✏️ <span id="form-title">@(isEditing ? "Cập nhật sản phẩm" : "Thêm sản phẩm mới")</span></h3>
                </div>

                <div class="admin-card-body">

                    <form class="product-form"
                          action="@productFormAction"
                          method="post"
                          enctype="multipart/form-data">

                        @if (isEditing)
                        {
                            <input type="hidden" name="Id" value="@editProduct!.Id" />
                        }

                        <div class="admin-form-group">
                            <label for="Name">
                                Tên sản phẩm <span style="color:var(--accent)">*</span>
                            </label>
                            <input type="text"
                                   id="Name"
                                   name="Name"
                                   value="@(isEditing ? editProduct!.Name : "")"
                                   placeholder="Ví dụ: Gundam RX-78-2 Ver.Ka MG 1/100"
                                   required />
                        </div>

                        <div class="admin-form-group">
                            <label for="Price">
                                Giá bán (VNĐ) <span style="color:var(--accent)">*</span>
                            </label>
                            <input type="number"
                                   id="Price"
                                   name="Price"
                                   value="@editPrice"
                                   placeholder="Ví dụ: 299000"
                                   min="0"
                                   step="1000"
                                   required />
                        </div>

                        <div class="admin-form-group">
                            <label for="categoryId">
                                Thể loại mô hình <span style="color:var(--accent)">*</span>
                            </label>
                            <select id="categoryId" name="categoryId" required>
                                <option value="">— Chọn thể loại —</option>
                                @foreach (var cat in categories)
                                {
                                    if (isEditing && editProduct!.CategoryId == cat.Id)
                                    {
                                        <option value="@cat.Id" selected>@cat.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@cat.Id">@cat.Name</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="admin-form-group form-full">
                            <label for="Description">
                                Mô tả chi tiết <span style="color:var(--accent)">*</span>
                            </label>
                            <textarea id="Description"
                                      name="Description"
                                      rows="3"
                                      placeholder="Nhập mô tả chi tiết sản phẩm..."
                                      required>@(isEditing ? editProduct!.Description : "")</textarea>
                        </div>

                        <div class="admin-form-group form-full">
                            <label>
                                Ảnh sản phẩm
                                <span style="font-weight:400;color:var(--text-light);font-size:0.82rem;">
                                    Có thể chọn nhiều ảnh một lần hoặc chọn nhiều lần khác nhau
                                </span>
                            </label>

                            @if (isEditing && editProduct!.Images != null && editProduct.Images.Any())
                            {
                                <div class="admin-existing-images-block">
                                    <div class="admin-image-title">Ảnh hiện tại</div>

                                    <div class="admin-img-preview-wrap" id="existing-images-wrap">
                                        @foreach (var img in editProduct.Images)
                                        {
                                            <div class="admin-img-preview-item existing-image-item"
                                                 id="existing-img-@img.Id"
                                                 data-image-id="@img.Id">

                                                <button type="button"
                                                        class="admin-img-remove-btn"
                                                        onclick="removeExistingImage(@img.Id)"
                                                        title="Xóa ảnh này">
                                                    ×
                                                </button>

                                                <img src="@img.Url"
                                                     alt="@editProduct.Name"
                                                     onerror="this.src='https://picsum.photos/seed/@img.Id/160/120'" />

                                                <div class="admin-img-name">Ảnh đã lưu</div>

                                                <input type="hidden"
                                                       name="keepImageIds"
                                                       value="@img.Id"
                                                       id="keep-img-@img.Id" />

                                                @if (editProduct.ImageUrl == img.Url)
                                                {
                                                    <span class="admin-preview-main-badge">Ảnh chính</span>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                            else if (isEditing && !string.IsNullOrEmpty(editProduct!.ImageUrl))
                            {
                                <div class="admin-existing-images-block">
                                    <div class="admin-image-title">Ảnh hiện tại</div>

                                    <div class="admin-img-preview-wrap">
                                        <div class="admin-img-preview-item">
                                            <img src="@editProduct.ImageUrl"
                                                 alt="@editProduct.Name"
                                                 onerror="this.src='https://picsum.photos/seed/@editProduct.Id/160/120'" />

                                            <div class="admin-img-name">Ảnh chính</div>
                                        </div>
                                    </div>
                                </div>
                            }

                            <div class="admin-new-images-block">
                                <div class="admin-image-title">Ảnh mới chọn</div>

                                <input type="file"
                                       id="imageFiles"
                                       name="imageFiles"
                                       accept="image/png,image/jpeg,image/jpg,image/webp"
                                       multiple
                                       hidden />

                                <button type="button"
                                        class="btn-select-images"
                                        id="btn-select-images">
                                    📷 Chọn ảnh sản phẩm
                                </button>

                                <small class="image-help-text">
                                    Ảnh mới sẽ được cộng thêm vào danh sách. Bấm dấu × để xóa ảnh trước khi lưu.
                                </small>

                                <div id="admin-new-img-preview-wrap" class="admin-img-preview-wrap">
                                    <div class="admin-img-empty">Chưa chọn ảnh mới nào.</div>
                                </div>
                            </div>
                        </div>


                        <div class="admin-form-group">
                            <label for="Badge">Badge</label>
                            <select id="Badge" name="Badge">
                                @if (!isEditing || editProduct!.Badge == "Hot")
                                {
                                    <option value="Hot" selected>🔥 Hot</option>
                                }
                                else
                                {
                                    <option value="Hot">🔥 Hot</option>
                                }

                                @if (isEditing && editProduct!.Badge == "Sale")
                                {
                                    <option value="Sale" selected>💸 Sale</option>
                                }
                                else
                                {
                                    <option value="Sale">💸 Sale</option>
                                }

                                @if (isEditing && editProduct!.Badge == "New")
                                {
                                    <option value="New" selected>🆕 New</option>
                                }
                                else
                                {
                                    <option value="New">🆕 New</option>
                                }

                                @if (isEditing && string.IsNullOrEmpty(editProduct!.Badge))
                                {
                                    <option value="" selected>— Không có —</option>
                                }
                                else
                                {
                                    <option value="">— Không có —</option>
                                }
                            </select>
                        </div>

                        <div class="admin-form-group">
                            <label for="Status">Trạng thái sản phẩm</label>
                            <select id="Status" name="Status">
                                @if (!isEditing || editProduct!.Status == "InStock")
                                {
                                    <option value="InStock" selected>🟢 Còn hàng</option>
                                }
                                else
                                {
                                    <option value="InStock">🟢 Còn hàng</option>
                                }

                                @if (isEditing && editProduct!.Status == "OutOfStock")
                                {
                                    <option value="OutOfStock" selected>🔴 Hết hàng</option>
                                }
                                else
                                {
                                    <option value="OutOfStock">🔴 Hết hàng</option>
                                }

                                @if (isEditing && editProduct!.Status == "ComingSoon")
                                {
                                    <option value="ComingSoon" selected>🟡 Sắp về hàng</option>
                                }
                                else
                                {
                                    <option value="ComingSoon">🟡 Sắp về hàng</option>
                                }
                            </select>
                        </div>

                        <div class="admin-form-group" id="stock-qty-wrap">
                            <label for="StockQty">Số lượng tồn kho</label>
                            <input type="number"
                                   id="StockQty"
                                   name="StockQty"
                                   value="@(isEditing ? editProduct!.StockQty : "")"
                                   placeholder="Ví dụ: 50"
                                   min="0" />
                        </div>

                        <div class="form-actions">
                            @if (isEditing)
                            {
                                <button class="btn-admin-primary" type="submit" style="background:#059669;">
                                    ✅ Cập nhật sản phẩm
                                </button>

                                <a asp-controller="Admin"
                                   asp-action="Index"
                                   class="btn-admin-cancel"
                                   style="text-decoration:none;display:inline-flex;align-items:center;">
                                    ✕ Hủy
                                </a>
                            }
                            else
                            {
                                <button class="btn-admin-primary" type="submit">
                                    ➕ Thêm sản phẩm
                                </button>
                            }
                        </div>
                    </form>

                </div>
            </div>

            <!-- PRODUCTS TABLE -->
            <div class="admin-card">
                <div class="admin-card-header admin-card-header-search">
                    <h3>📋 Danh sách sản phẩm (@(ViewBag.TotalCount ?? 0))</h3>

                    <form asp-controller="Admin" asp-action="Index" method="get" class="admin-search-form">
                        <input type="text" name="search" value="@(ViewBag.Search as string)"
                               placeholder="🔍 Tìm theo tên sản phẩm..." class="admin-search-input" />
                        <button type="submit" class="admin-search-btn">Tìm</button>
                        @if (!string.IsNullOrEmpty(ViewBag.Search as string))
                        {
                            <a asp-action="Index" class="admin-search-clear">✕ Xóa lọc</a>
                        }
                    </form>
                </div>

                <div class="admin-card-body" style="padding:0;">
                    <div class="products-table-wrap">
                        <table class="products-table table table-hover table-striped"
                               role="table"
                               aria-label="Danh sách sản phẩm">

                            <thead>
                                <tr>
                                    <th scope="col">Ảnh</th>
                                    <th scope="col">Tên sản phẩm</th>
                                    <th scope="col">Giá bán</th>
                                    <th scope="col">Mô tả</th>
                                    <th scope="col">Badge</th>
                                    <th scope="col">Tồn kho</th>
                                    <th scope="col">Thao tác</th>
                                </tr>
                            </thead>

                            <tbody>
                                @if (products.Any())
                                {
                                    foreach (var product in products)
                                    {
                                        var imgCount = product.Images != null ? product.Images.Count : 0;

                                        <tr>
                                            <td>
                                                <div class="table-img-wrap">
                                                    <img class="table-img"
                                                         src="@product.ImageUrl"
                                                         alt="@product.Name"
                                                         onerror="this.src='https://picsum.photos/seed/@product.Id/100/100'" />

                                                    @if (imgCount > 1)
                                                    {
                                                        <span class="img-count-badge">+@(imgCount - 1)</span>
                                                    }
                                                </div>
                                            </td>

                                            <td class="table-name">@product.Name</td>

                                            <td class="table-price">@product.Price.ToString("#,##0") đ</td>

                                            <td class="table-desc">@product.Description</td>

                                            <td>
                                                @if (!string.IsNullOrEmpty(product.Badge))
                                                {
                                                    <span class="product-badge">@product.Badge</span>
                                                }
                                                else
                                                {
                                                    <span>—</span>
                                                }
                                            </td>

                                            <td>
                                                @if (product.Status == "ComingSoon")
                                                {
                                                    <span class="stock-badge stock-coming">🟡 Sắp về hàng</span>
                                                }
                                                else if (product.Status == "OutOfStock")
                                                {
                                                    <span class="stock-badge stock-out">🔴 Hết hàng</span>
                                                }
                                                else
                                                {
                                                    <span class="stock-badge stock-in">🟢 Còn hàng</span>
                                                    <small class="stock-qty">(@product.StockQty cái)</small>
                                                }
                                            </td>

                                            <td>
                                                <div style="display:flex;gap:8px;align-items:center;">
                                                    <a asp-controller="Admin"
                                                       asp-action="Index"
                                                       asp-route-editId="@product.Id"
                                                       class="btn-edit"
                                                       style="text-decoration:none;">
                                                        ✏️ Sửa
                                                    </a>

                                                    <form asp-controller="Admin"
                                                          asp-action="DeleteProduct"
                                                          method="post"
                                                          onsubmit="return confirm('Bạn có chắc muốn xóa sản phẩm này không?');">
                                                        <input type="hidden" name="id" value="@product.Id" />
                                                        <button type="submit" class="btn-delete">🗑 Xóa</button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7">
                                            <div class="empty-state">
                                                <div class="empty-icon">📦</div>
                                                <p>Chưa có sản phẩm nào trong SQL Server.</p>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>

                        </table>
                    </div>

                    @{
                        int curPage = ViewBag.CurrentPage != null ? (int)ViewBag.CurrentPage : 1;
                        int totPages = ViewBag.TotalPages != null ? (int)ViewBag.TotalPages : 1;
                        string sv = ViewBag.Search as string ?? "";
                    }
                    @if (totPages > 1)
                    {
                        <nav class="admin-pagination" aria-label="Phân trang sản phẩm">
                            @if (curPage > 1)
                            {
                                <a asp-action="Index" asp-route-search="@sv" asp-route-page="@(curPage - 1)" class="page-link">‹ Trước</a>
                            }
                            @for (int i = 1; i <= totPages; i++)
                            {
                                <a asp-action="Index" asp-route-search="@sv" asp-route-page="@i" class="page-link @(i == curPage ? "active" : "")">@i</a>
                            }
                            @if (curPage < totPages)
                            {
                                <a asp-action="Index" asp-route-search="@sv" asp-route-page="@(curPage + 1)" class="page-link">Sau ›</a>
                            }
                        </nav>
                    }
                </div>
            </div>

            <!-- ========== QUẢN LÝ DANH MỤC (gộp chung trang) ========== -->
            <div id="admin-category-section" style="margin-top:8px;">

                @if (TempData["CatSuccess"] != null)
                {
                    <div class="cat-alert cat-alert-ok">✅ @TempData["CatSuccess"]</div>
                }
                @if (TempData["CatError"] != null)
                {
                    <div class="cat-alert cat-alert-err">⚠️ @TempData["CatError"]</div>
                }

                <!-- FORM THÊM / SỬA DANH MỤC -->
                <div class="admin-card">
                    <div class="admin-card-header">
                        <h3>@(isEditingCat ? "✏️ Sửa thể loại" : "🗂️ Thêm thể loại mới")</h3>
                    </div>
                    <div class="admin-card-body">
                        @if (isEditingCat)
                        {
                            <form asp-controller="Admin" asp-action="EditCategory" method="post" class="cat-form">
                                <input type="hidden" name="id" value="@editCategory!.Id" />
                                <div class="cat-form-row">
                                    <input type="text" name="name" value="@editCategory.Name" class="admin-search-input" placeholder="Tên thể loại..." required />
                                    <button type="submit" class="btn-admin-primary">💾 Cập nhật</button>
                                    <a asp-action="Index" class="btn-cat-cancel">✕ Hủy</a>
                                </div>
                            </form>
                        }
                        else
                        {
                            <form asp-controller="Admin" asp-action="AddCategory" method="post" class="cat-form">
                                <div class="cat-form-row">
                                    <input type="text" name="name" class="admin-search-input" placeholder="Ví dụ: Gundam, Figure, Anime..." required />
                                    <button type="submit" class="btn-admin-primary">➕ Thêm thể loại</button>
                                </div>
                            </form>
                        }
                    </div>
                </div>

                <!-- BẢNG DANH MỤC -->
                <div class="admin-card">
                    <div class="admin-card-header admin-card-header-search">
                        <h3>📋 Danh sách thể loại (@(ViewBag.CatTotalCount ?? 0))</h3>
                        <form asp-controller="Admin" asp-action="Index" method="get" class="admin-search-form">
                            <input type="text" name="catSearch" value="@catSv" placeholder="🔍 Tìm thể loại..." class="admin-search-input" />
                            <button type="submit" class="admin-search-btn">Tìm</button>
                            @if (!string.IsNullOrEmpty(catSv))
                            {
                                <a asp-action="Index" class="admin-search-clear">✕ Xóa lọc</a>
                            }
                        </form>
                    </div>
                    <div class="admin-card-body" style="padding:0;">
                        <div class="products-table-wrap">
                            <table class="products-table table table-hover table-striped">
                                <thead>
                                    <tr>
                                        <th scope="col">#</th>
                                        <th scope="col">Tên thể loại</th>
                                        <th scope="col">Số sản phẩm</th>
                                        <th scope="col">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (categoriesPaged.Any())
                                    {
                                        foreach (var cat in categoriesPaged)
                                        {
                                            var pc = cat.Products != null ? cat.Products.Count : 0;
                                            <tr>
                                                <td>@cat.Id</td>
                                                <td class="table-name">@cat.Name</td>
                                                <td><span class="stock-badge stock-in">@pc sản phẩm</span></td>
                                                <td>
                                                    <div style="display:flex;gap:8px;align-items:center;">
                                                        <a href="/Admin?catSearch=@catSv&catPage=@catCurPage&editCatId=@cat.Id#admin-category-section" class="btn-edit" style="text-decoration:none;">✏️ Sửa</a>
                                                        <form asp-controller="Admin" asp-action="DeleteCategory" method="post" onsubmit="return confirm('Xóa thể loại này?');">
                                                            <input type="hidden" name="id" value="@cat.Id" />
                                                            <button type="submit" class="btn-delete">🗑 Xóa</button>
                                                        </form>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="4">
                                                <div class="empty-state">
                                                    <div class="empty-icon">🗂️</div>
                                                    <p>Chưa có thể loại nào@(string.IsNullOrEmpty(catSv) ? "." : " khớp tìm kiếm.")</p>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (catTotPages > 1)
                        {
                            <nav class="admin-pagination" aria-label="Phân trang danh mục">
                                @if (catCurPage > 1)
                                {
                                    <a href="/Admin?catSearch=@catSv&catPage=@(catCurPage - 1)#admin-category-section" class="page-link">‹ Trước</a>
                                }
                                @for (int i = 1; i <= catTotPages; i++)
                                {
                                    <a href="/Admin?catSearch=@catSv&catPage=@i#admin-category-section" class="page-link @(i == catCurPage ? "active" : "")">@i</a>
                                }
                                @if (catCurPage < catTotPages)
                                {
                                    <a href="/Admin?catSearch=@catSv&catPage=@(catCurPage + 1)#admin-category-section" class="page-link">Sau ›</a>
                                }
                            </nav>
                        }
                    </div>
                </div>
            </div>

            @if (isEditingCat || !string.IsNullOrEmpty(catSv))
            {
                <script>
                                document.getElementById('admin-category-section')?.scrollIntoView({ behavior: 'smooth' });
                </script>
            }

        </main>
    </div>
</section>
<script>
    let selectedProductImages = [];

    const imageInput = document.getElementById('imageFiles');
    const selectImagesBtn = document.getElementById('btn-select-images');
    const newPreviewWrap = document.getElementById('admin-new-img-preview-wrap');

    if (selectImagesBtn && imageInput) {
        selectImagesBtn.addEventListener('click', function () {
            imageInput.value = '';
            imageInput.click();
        });
    }

    if (imageInput) {
        imageInput.addEventListener('change', function (event) {
            const newFiles = Array.from(event.target.files || []);

            newFiles.forEach(file => {
                if (!file.type.startsWith('image/')) {
                    return;
                }

                const isDuplicate = selectedProductImages.some(existing =>
                    existing.name === file.name &&
                    existing.size === file.size &&
                    existing.lastModified === file.lastModified
                );

                if (!isDuplicate) {
                    selectedProductImages.push(file);
                }
            });

            syncImageInputFiles();
            renderSelectedImages();
        });
    }

    function renderSelectedImages() {
        if (!newPreviewWrap) return;

        if (selectedProductImages.length === 0) {
            newPreviewWrap.innerHTML = `
                <div class="admin-img-empty">
                    Chưa chọn ảnh mới nào.
                </div>
            `;
            return;
        }

        newPreviewWrap.innerHTML = '';

        selectedProductImages.forEach((file, index) => {
            const reader = new FileReader();

            reader.onload = function (e) {
                const item = document.createElement('div');
                item.className = 'admin-img-preview-item';

                item.innerHTML = `
                    <button type="button"
                            class="admin-img-remove-btn"
                            onclick="removeSelectedImage(${index})"
                            title="Xóa ảnh này">
                        ×
                    </button>

                    <img src="${e.target.result}" alt="${file.name}" />

                    <div class="admin-img-name" title="${file.name}">
                        ${file.name}
                    </div>

                    ${index === 0 ? '<span class="admin-preview-main-badge">Ảnh mới</span>' : ''}
                `;

                newPreviewWrap.appendChild(item);
            };

            reader.readAsDataURL(file);
        });
    }

    function removeSelectedImage(index) {
        selectedProductImages.splice(index, 1);
        syncImageInputFiles();
        renderSelectedImages();
    }

    function syncImageInputFiles() {
        if (!imageInput) return;

        const dataTransfer = new DataTransfer();

        selectedProductImages.forEach(file => {
            dataTransfer.items.add(file);
        });

        imageInput.files = dataTransfer.files;
    }

    function removeExistingImage(imageId) {
        const imageItem = document.getElementById(`existing-img-${imageId}`);
        const keepInput = document.getElementById(`keep-img-${imageId}`);

        if (imageItem) {
            imageItem.remove();
        }

        if (keepInput) {
            keepInput.remove();
        }

        const existingWrap = document.getElementById('existing-images-wrap');

        if (existingWrap && existingWrap.querySelectorAll('.existing-image-item').length === 0) {
            existingWrap.innerHTML = `
                <div class="admin-img-empty">
                    Tất cả ảnh cũ đã được loại khỏi lần cập nhật này.
                </div>
            `;
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        renderSelectedImages();
    });
</script>

<script>
    // Xóa từng ảnh sản phẩm (gọi API /Admin/DeleteImage đã có sẵn)
    function deleteProductImage(imageId, productId, btn) {
        if (!confirm('Xóa ảnh này khỏi sản phẩm?')) return;

        fetch('/Admin/DeleteImage', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'imageId=' + imageId + '&productId=' + productId
        })
        .then(function (r) { return r.json(); })
        .then(function (data) {
            if (data.success) {
                var item = btn.closest('.admin-img-item');
                if (item) item.remove();
            } else {
                alert(data.message || 'Không xóa được ảnh.');
            }
        })
        .catch(function () { alert('Lỗi kết nối, vui lòng thử lại.'); });
    }
</script>
