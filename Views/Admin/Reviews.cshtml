@model List<ProductReviewModel>
@using ProductReviewModel = bt1.Product.ProductReview;

@{
    ViewData["Title"] = "Quản Lý Review";
}

<div class="container" style="padding: 40px 0;">
    <a href="/Admin/Dashboard" style="color: #3b82f6; text-decoration: none; font-weight: 600; margin-bottom: 20px; display: inline-block;">← Dashboard</a>

    <h1>⭐ Danh Sách Review</h1>
    <p style="color: #64748b;">Xem tất cả đánh giá của khách hàng.</p>

    <table style="width: 100%; border-collapse: collapse; margin-top: 30px;">
        <thead>
            <tr style="border-bottom: 2px solid #e5e7eb; background: #f9fafb;">
                <th style="padding: 15px; text-align: left;">Khách Hàng</th>
                <th style="padding: 15px; text-align: left;">Bình Luận</th>
                <th style="padding: 15px; text-align: center;">Rating</th>
                <th style="padding: 15px; text-align: center;">Ngày</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var review in Model)
            {
                <tr style="border-bottom: 1px solid #e5e7eb;">
                    <td style="padding: 15px;">@review.CustomerName</td>
                    <td style="padding: 15px;">@review.Comment</td>
                    <td style="padding: 15px; text-align: center;">⭐ @review.Rating</td>
                    <td style="padding: 15px; text-align: center;">@review.CreatedAt.ToString("dd/MM/yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    .container {
        max-width: 1200px;
        margin: 0 auto;
    }
</style>