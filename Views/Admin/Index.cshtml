<!-- ============================================================
     MÀN HÌNH ADMIN
     ============================================================ -->
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Admin - Quản lý sản phẩm";
}
<section id="admin-page" class="page-section">

    <!-- ADMIN NAVBAR -->
    <nav class="admin-navbar" role="navigation" aria-label="Admin navigation">
        <div class="admin-navbar-inner">
            <div class="admin-logo">
                🛍️ HNTS
                <span class="admin-logo-badge">Admin</span>
            </div>
            <ul class="admin-nav-links" role="list">
                <li>
                    <a href="#" class="active" onclick="return false;">📦 Quản lý sản phẩm</a>
                </li>
                <li>
                    <button id="admin-logout-btn" type="button">🚪 Đăng xuất</button>
                </li>
            </ul>
        </div>
    </nav>

    <!-- ADMIN LAYOUT -->
    <div class="admin-layout">

        <!-- Sidebar -->
        <aside class="admin-sidebar" role="complementary" aria-label="Sidebar">
            <div class="sidebar-section">
                <div class="sidebar-title">Tổng quan</div>
                <button class="sidebar-link active" type="button">
                    <span class="icon">📊</span> Dashboard
                </button>
                <button class="sidebar-link" type="button"
                        onclick="document.getElementById('product-form-section').scrollIntoView({behavior:'smooth'})">
                    <span class="icon">📦</span> Quản lý sản phẩm
                </button>
            </div>
            <div class="sidebar-section">
                <div class="sidebar-title">Hệ thống</div>
                <button class="sidebar-link" type="button" id="sidebar-logout">
                    <span class="icon">🚪</span> Đăng xuất
                </button>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="admin-main" role="main">

            <!-- Page Title -->
            <div class="mb-4">
                <h1 style="font-family:var(--font-display);font-size:1.7rem;font-weight:700;color:var(--admin-primary);letter-spacing:-0.5px;">
                    📦 Quản lý sản phẩm
                </h1>
                <p style="color:#94a3b8;font-size:0.9rem;margin-top:4px;">
                    Thêm, sửa, xóa và quản lý toàn bộ sản phẩm trên cửa hàng.
                </p>
            </div>

            <!-- STATS GRID -->
            <div class="stats-grid">
                <div class="stat-card shadow-sm">
                    <div class="stat-icon blue">📦</div>
                    <div class="stat-info">
                        <div class="stat-val" id="stat-total">—</div>
                        <div class="stat-lbl">Tổng sản phẩm</div>
                    </div>
                </div>
                <div class="stat-card shadow-sm">
                    <div class="stat-icon red">🏆</div>
                    <div class="stat-info">
                        <div class="stat-val" id="stat-max-price" style="font-size:1.15rem;">—</div>
                        <div class="stat-lbl">Giá cao nhất</div>
                    </div>
                </div>
                <div class="stat-card shadow-sm">
                    <div class="stat-icon green">💰</div>
                    <div class="stat-info">
                        <div class="stat-val" id="stat-total-value" style="font-size:1.15rem;">—</div>
                        <div class="stat-lbl">Tổng giá trị</div>
                    </div>
                </div>
                <div class="stat-card shadow-sm">
                    <div class="stat-icon orange">🚫</div>
                    <div class="stat-info">
                        <div class="stat-val" id="stat-out-of-stock">—</div>
                        <div class="stat-lbl">Hết hàng</div>
                    </div>
                </div>
            </div>

            <!-- PRODUCT FORM -->
            <div class="admin-card" id="product-form-section">
                <div class="admin-card-header">
                    <h3>✏️ <span id="form-title">Thêm sản phẩm mới</span></h3>
                </div>
                <div class="admin-card-body">
                    <div class="product-form">

                        <div class="admin-form-group">
                            <label for="prod-name">Tên sản phẩm <span style="color:var(--accent)">*</span></label>
                            <input type="text" id="prod-name" placeholder="Ví dụ: Áo Thun Cotton Cao Cấp" />
                        </div>

                        <div class="admin-form-group">
                            <label for="prod-price">Giá bán (VNĐ) <span style="color:var(--accent)">*</span></label>
                            <input type="number" id="prod-price" placeholder="Ví dụ: 299000" min="0" />
                        </div>

                        <div class="admin-form-group form-full">
                            <label for="prod-desc">Mô tả chi tiết <span style="color:var(--accent)">*</span></label>
                            <textarea id="prod-desc" rows="3" placeholder="Nhập mô tả chi tiết sản phẩm..."></textarea>
                        </div>

                        <div class="admin-form-group form-full">
                            <label for="prod-img-file">Ảnh sản phẩm <span style="font-weight:400;color:var(--text-light);font-size:0.82rem;">(tối đa 5 ảnh – Ctrl+click để chọn nhiều)</span></label>
                            <div class="multi-img-upload-wrap">
                                <input type="file" id="prod-img-file" accept="image/*" multiple />
                                <span class="multi-img-hint">📎 Chọn 1 hoặc nhiều ảnh cùng lúc</span>
                            </div>
                            <!-- Khu vực preview nhiều ảnh -->
                            <div id="admin-img-preview-wrap" class="admin-img-preview-wrap"></div>
                        </div>

                        <div class="admin-form-group">
                            <label for="prod-badge">Badge</label>
                            <select id="prod-badge">
                                <option value="Hot">🔥 Hot</option>
                                <option value="Sale">💸 Sale</option>
                                <option value="New">🆕 New</option>
                                <option value="">— Không có —</option>
                            </select>
                        </div>

                        <!-- TRẠNG THÁI TỒN KHO -->
                        <!-- TRẠNG THÁI SẢN PHẨM -->
                        <div class="admin-form-group">
                            <label for="prod-status">Trạng thái sản phẩm</label>
                            <select id="prod-status">
                                <option value="InStock">🟢 Còn hàng</option>
                                <option value="OutOfStock">🔴 Hết hàng</option>
                                <option value="ComingSoon">🟡 Sắp về hàng</option>
                            </select>
                        </div>

                        <div class="admin-form-group" id="stock-qty-wrap">
                            <label for="prod-stock-qty">Số lượng tồn kho</label>
                            <input type="number" id="prod-stock-qty" placeholder="Ví dụ: 50" min="0" />
                        </div>

                        <div class="form-actions">
                            <button class="btn-admin-primary" id="btn-add" type="button">➕ Thêm sản phẩm</button>
                            <button class="btn-admin-primary hidden" id="btn-update" type="button"
                                    style="background:#059669;">
                                ✅ Cập nhật
                            </button>
                            <button class="btn-admin-cancel hidden" id="btn-cancel" type="button">✕ Hủy</button>
                        </div>

                    </div>
                </div>
            </div>

            <!-- PRODUCTS TABLE -->
            <div class="admin-card">
                <div class="admin-card-header">
                    <h3>📋 Danh sách sản phẩm</h3>
                    <div class="table-toolbar">
                        <div class="search-input-wrap">
                            <span class="search-icon">🔍</span>
                            <input type="search" id="search-products"
                                   placeholder="Tìm kiếm sản phẩm..." aria-label="Tìm kiếm sản phẩm" />
                        </div>
                    </div>
                </div>
                <div class="admin-card-body" style="padding:0;">
                    <div class="products-table-wrap">
                        <table class="products-table table table-hover table-striped" role="table" aria-label="Danh sách sản phẩm">
                            <thead>
                                <tr>
                                    <th scope="col">Ảnh</th>
                                    <th scope="col">Tên sản phẩm</th>
                                    <th scope="col">Giá bán</th>
                                    <th scope="col">Mô tả</th>
                                    <th scope="col">Badge</th>
                                    <th scope="col">Tồn kho</th>
                                    <th scope="col">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody id="admin-products-body">
                                <!-- Rows injected by JS -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </main>
    </div><!-- end admin-layout -->
</section><!-- end admin-page -->
